# -----------------------------
# Core
# -----------------------------
NODE_ENV=production
PUBLIC_BASE_URL=https://fastaccs.vercel.app
PUBLIC_SITE_URL=https://fastaccs.vercel.app

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# -----------------------------
# Cloudinary (Tier Samples)
# -----------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional (defaults shown)
# CLOUDINARY_UPLOAD_PREFIX=https://api.cloudinary.com
# CLOUDINARY_UPLOAD_FOLDER=tier-samples

# -----------------------------
# Admin / Auth
# -----------------------------
ADMIN_EMAILS=admin@example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------
# Monnify
# -----------------------------
MONNIFY_BASE_URL=https://api.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=

# -----------------------------
# Email (preferred SMTP)
# -----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM_NAME=Fast Accounts
SMTP_FROM_EMAIL=no-reply@fastaccs.com

# -----------------------------
# Email (legacy Gmail fallback)
# Keep blank if using SMTP above.
# -----------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=

# -----------------------------
# Email verification + campaigns
# -----------------------------
VERIFICATION_CODE_EXPIRY_MINUTES=10
WINBACK_DAYS_THRESHOLD=30
WINBACK_SCHEDULER_ENABLED=false
WINBACK_SCHEDULER_INTERVAL_MS=900000
BROADCAST_BATCH_SIZE=10
BROADCAST_BATCH_DELAY_MS=1000

# -----------------------------
# Payment reconciliation scheduler
# -----------------------------
PAYMENT_RECONCILE_SCHEDULER=true
PAYMENT_RECONCILE_INTERVAL_MS=300000
