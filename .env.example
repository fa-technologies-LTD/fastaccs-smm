# -----------------------------
# Core
# -----------------------------
NODE_ENV=production
PUBLIC_BASE_URL=https://smm.fastaccs.com
PUBLIC_SITE_URL=https://smm.fastaccs.com
# Optional private fallback canonical base URL used for server redirects
CANONICAL_BASE_URL=https://smm.fastaccs.com
# Optional: comma-separated legacy hosts that should 308 redirect to PUBLIC_BASE_URL
CANONICAL_REDIRECT_SOURCE_HOSTS=fastaccs-smm.vercel.app

# -----------------------------
# Analytics
# -----------------------------
PUBLIC_GA4_MEASUREMENT_ID=G-YQE09MPX5H
# Optional: set true only when intentionally testing GA4 from local/dev hosts.
PUBLIC_GA4_DEBUG=false
# Private GA4 Measurement Protocol API secret from the web data stream.
GA4_MEASUREMENT_PROTOCOL_API_SECRET=

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# -----------------------------
# Cloudinary (Tier Samples)
# -----------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional (defaults shown)
# CLOUDINARY_UPLOAD_PREFIX=https://api.cloudinary.com
# CLOUDINARY_UPLOAD_FOLDER=tier-samples
# CLOUDINARY_EXACT_PREVIEW_FOLDER=exact-preview-thumbnails

# -----------------------------
# Admin / Auth
# -----------------------------
ADMIN_EMAILS=admin@example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------
# Monnify
# -----------------------------
MONNIFY_BASE_URL=https://api.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
# Emergency control: blocks only new payment initialization when true.
# Existing carts, orders, and active hosted checkout evidence remain stored.
CHECKOUT_DISABLED=false

# -----------------------------
# Email (preferred SMTP)
# -----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM_NAME=Fast Accounts
SMTP_FROM_EMAIL=no-reply@fastaccs.com

# -----------------------------
# Email (legacy Gmail fallback)
# Keep blank if using SMTP above.
# -----------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=

# -----------------------------
# Email verification + campaigns
# -----------------------------
VERIFICATION_CODE_EXPIRY_MINUTES=10
WINBACK_DAYS_THRESHOLD=30
BROADCAST_BATCH_SIZE=10
BROADCAST_BATCH_DELAY_MS=1000

# -----------------------------
# Cron auth (Vercel cron endpoints)
# -----------------------------
# Set this in production; Vercel cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
