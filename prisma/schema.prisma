generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String?             @unique
  googleId                String?             @unique @map("google_id")
  fullName                String?             @map("full_name")
  avatarUrl               String?             @map("avatar_url")
  phone                   String?
  guestSessionId          String?             @unique @map("guest_session_id")
  dailyPurchaseLimit      Int                 @default(100) @map("daily_purchase_limit")
  totalPurchaseLimit      Int                 @default(1000) @map("total_purchase_limit")
  restrictedCategories    String[]            @map("restricted_categories")
  isActive                Boolean             @default(true) @map("is_active")
  emailVerified           Boolean             @default(false) @map("email_verified")
  registeredAt            DateTime            @default(now()) @map("registered_at")
  lastLogin               DateTime?           @map("last_login")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @default(now()) @map("updated_at")
  userType                UserType            @default(REGISTERED) @map("user_type")
  preferredDeliveryMethod DeliveryMethod      @default(EMAIL) @map("preferred_delivery_method")
  isAffiliateEnabled      Boolean             @default(false) @map("is_affiliate_enabled")
  affiliatePrograms       AffiliateProgram[]
  cartItems               CartItem[]
  notifications           Notification[]
  affiliateOrders         Order[]             @relation("AffiliateOrders")
  orders                  Order[]
  reviews                 Review[]
  sessions                Session[]
  walletTransactions      WalletTransaction[]
  wallet                  Wallet?

  @@map("users")
}

model Category {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId       String?        @map("parent_id") @db.Uuid
  name           String
  slug           String
  description    String?
  categoryType   String         @map("category_type")
  metadata       Json           @default("{}")
  sortOrder      Int            @default(0) @map("sort_order")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @map("updated_at")
  accountBatches AccountBatch[]
  accounts       Account[]
  cartItems      CartItem[]
  parent         Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       Category[]     @relation("CategoryHierarchy")
  orderItems     OrderItem[]
  reviews        Review[]

  @@index([parentId])
  @@index([slug, isActive])
  @@index([categoryType, isActive])
  @@index([categoryType, parentId, isActive])
  @@index([isActive, sortOrder])
  @@map("categories")
}

model AccountBatch {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String    @map("category_id") @db.Uuid
  supplier       String?
  costPerUnit    Decimal?  @map("cost_per_unit")
  descriptors    Json      @default("{}")
  linksRaw       String?   @map("links_raw")
  logsRaw        String?   @map("logs_raw")
  notes          String?
  totalUnits     Int       @map("total_units")
  remainingUnits Int       @default(0) @map("remaining_units")
  importStatus   String    @default("pending") @map("import_status")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @map("updated_at")
  category       Category  @relation(fields: [categoryId], references: [id])
  accounts       Account[]

  @@index([categoryId])
  @@index([importStatus])
  @@index([categoryId, importStatus])
  @@map("account_batches")
}

model Account {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId          String       @map("batch_id") @db.Uuid
  categoryId       String       @map("category_id") @db.Uuid
  platform         String
  linkUrl          String?      @map("link_url")
  username         String?
  password         String?
  email            String?
  emailPassword    String?      @map("email_password")
  twoFa            String?      @map("two_fa")
  twoFactorEnabled Boolean?     @map("two_factor_enabled")
  easyLoginEnabled Boolean?     @map("easy_login_enabled")
  followers        Int?
  following        Int?
  postsCount       Int?         @map("posts_count")
  engagementRate   Decimal?     @map("engagement_rate")
  ageMonths        Int?         @map("age_months")
  niche            String?
  qualityScore     Int?         @map("quality_score")
  status           String       @default("available")
  reservedUntil    DateTime?    @map("reserved_until")
  orderItemId      String?      @map("order_item_id") @db.Uuid
  deliveredAt      DateTime?    @map("delivered_at")
  deliveryNotes    String?      @map("delivery_notes")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @default(now()) @map("updated_at")
  batch            AccountBatch @relation(fields: [batchId], references: [id])
  category         Category     @relation(fields: [categoryId], references: [id])
  orderItem        OrderItem?   @relation(fields: [orderItemId], references: [id])

  @@index([batchId])
  @@index([categoryId])
  @@index([status])
  @@index([categoryId, status])
  @@index([status, reservedUntil])
  @@index([orderItemId])
  @@map("accounts")
}

model Order {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber        String         @unique @map("order_number")
  userId             String?        @map("user_id") @db.Uuid
  guestEmail         String?        @map("guest_email")
  guestPhone         String?        @map("guest_phone")
  emailVerified      Boolean        @default(false) @map("email_verified")
  verificationToken  String?        @map("verification_token")
  verificationSentAt DateTime?      @map("verification_sent_at")
  subtotal           Decimal
  taxAmount          Decimal        @default(0) @map("tax_amount")
  discountAmount     Decimal        @default(0) @map("discount_amount")
  totalAmount        Decimal        @map("total_amount")
  currency           String         @default("NGN")
  paymentMethod      String?        @map("payment_method")
  paymentReference   String?        @map("payment_reference")
  paymentStatus      String         @default("pending") @map("payment_status")
  paidAt             DateTime?      @map("paid_at")
  deliveryMethod     String         @map("delivery_method")
  deliveryContact    String         @map("delivery_contact")
  deliveryStatus     String         @default("pending") @map("delivery_status")
  deliveredAt        DateTime?      @map("delivered_at")
  status             String         @default("pending")
  affiliateCode      String?        @map("affiliate_code")
  affiliateUserId    String?        @map("affiliate_user_id") @db.Uuid
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @default(now()) @map("updated_at")
  paymentChannel     String?        @map("payment_channel")
  notifications      Notification[]
  orderItems         OrderItem[]
  affiliateUser      User?          @relation("AffiliateOrders", fields: [affiliateUserId], references: [id])
  user               User?          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus])
  @@index([affiliateUserId])
  @@index([affiliateCode])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String    @map("order_id") @db.Uuid
  quantity         Int
  unitPrice        Decimal   @map("unit_price")
  totalPrice       Decimal   @map("total_price")
  productName      String    @map("product_name")
  productCategory  String    @map("product_category")
  allocationStatus String    @default("pending") @map("allocation_status")
  allocatedCount   Int       @default(0) @map("allocated_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")
  categoryId       String    @map("category_id") @db.Uuid
  accounts         Account[]
  category         Category  @relation(fields: [categoryId], references: [id])
  order            Order     @relation(fields: [orderId], references: [id])
  reviews          Review[]

  @@index([orderId])
  @@index([categoryId])
  @@index([allocationStatus])
  @@map("order_items")
}

model CartItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  quantity   Int
  addedAt    DateTime @default(now()) @map("added_at")
  categoryId String   @map("category_id") @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@map("cart_items")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String
  title     String
  message   String
  orderId   String?   @map("order_id") @db.Uuid
  read      Boolean   @default(false)
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")
  order     Order?    @relation(fields: [orderId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt])
  @@index([orderId])
  @@index([expiresAt])
  @@map("notifications")
}

model Review {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  orderItemId String?    @map("order_item_id") @db.Uuid
  rating      Int
  title       String?
  content     String?
  imageUrls   String[]   @map("image_urls")
  status      String     @default("published")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @default(now()) @map("updated_at")
  categoryId  String     @map("category_id") @db.Uuid
  category    Category   @relation(fields: [categoryId], references: [id])
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
  user        User       @relation(fields: [userId], references: [id])

  @@index([categoryId])
  @@index([userId])
  @@index([orderItemId])
  @@index([status, createdAt])
  @@map("reviews")
}

model AffiliateProgram {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  affiliateCode     String             @unique @map("affiliate_code")
  commissionRate    Decimal            @default(10.00) @map("commission_rate")
  totalReferrals    Int                @default(0) @map("total_referrals")
  totalSales        Decimal            @default(0) @map("total_sales")
  totalCommission   Decimal            @default(0) @map("total_commission")
  status            String             @default("active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @map("updated_at")
  totalPaid         Decimal            @default(0) @map("total_paid")
  user              User               @relation(fields: [userId], references: [id])
  commissionPayouts CommissionPayout[]

  @@index([userId])
  @@index([status])
  @@map("affiliate_programs")
}

model CommissionPayout {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  affiliateProgramId String           @map("affiliate_program_id") @db.Uuid
  amount             Decimal
  payoutMethod       String           @map("payout_method")
  payoutReference    String?          @map("payout_reference")
  payoutDate         DateTime         @map("payout_date")
  notes              String?
  processedBy        String?          @map("processed_by") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @default(now()) @map("updated_at")
  affiliateProgram   AffiliateProgram @relation(fields: [affiliateProgramId], references: [id])

  @@index([affiliateProgramId])
  @@index([payoutDate])
  @@map("commission_payouts")
}

model Session {
  id              String   @id
  userId          String   @map("user_id") @db.Uuid
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Wallet {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String              @unique @map("user_id") @db.Uuid
  balance      Decimal             @default(0) @db.Decimal(10, 2)
  currency     String              @default("NGN")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @default(now()) @map("updated_at")
  transactions WalletTransaction[]
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WalletTransaction {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId      String   @map("wallet_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  type          String
  amount        Decimal  @db.Decimal(10, 2)
  balanceBefore Decimal  @map("balance_before") @db.Decimal(10, 2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(10, 2)
  description   String
  reference     String?  @unique
  paymentMethod String?  @map("payment_method")
  status        String   @default("pending")
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([type])
  @@index([status])
  @@map("wallet_transactions")
}

model Microcopy {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique
  value       String
  description String?
  category    String   @default("general")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@index([category, isActive])
  @@map("microcopy")
}

enum UserType {
  REGISTERED
  GUEST
  CONVERTED
  AFFILIATE
  ADMIN
}

enum DeliveryMethod {
  EMAIL
  DASHBOARD
}
