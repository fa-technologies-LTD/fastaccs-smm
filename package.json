{
	"name": "fastaccs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=20.12.0 <21"
	},
	"scripts": {
		"verify:runtime": "node ./scripts/verify-runtime.mjs",
		"prisma:generate": "prisma generate",
		"prisma:deploy": "prisma migrate deploy",
		"dev": "npm run verify:runtime && npm run prisma:generate && vite dev",
		"build": "npm run verify:runtime && npm run prisma:generate && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "npm run prisma:generate",
		"check": "npm run verify:runtime && npm run prisma:generate && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"release:verify": "npm run prisma:deploy && npm run check && npm run build",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@playwright/test": "^1.49.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^24.3.0",
		"@vitest/browser": "^3.2.3",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"playwright": "^1.53.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.2.6",
		"vitest": "^3.2.3",
		"vitest-browser-svelte": "^0.1.0"
	},
	"dependencies": {
		"@lucide/svelte": "^0.536.0",
		"@prisma/client": "^6.16.3",
		"@types/nodemailer": "^7.0.2",
		"arctic": "^3.7.0",
		"gsap": "^3.14.2",
		"nodemailer": "^7.0.7",
		"prisma": "^6.16.3"
	}
}
